{
  "id": "everforest-dark",
  "name": "Everforest",
  "appearance": "dark",
  "colors": {
    "bg-deep": "#232a2e",
    "bg-sunken": "#343f44",
    "bg": "#2d353b",
    "surface": "#3d484d",
    "surface-2": "#475258",
    "surface-3": "#56635f",
    "text-ghost": "#7a8478",
    "text-faint": "#859289",
    "text-disabled": "#9da9a0",
    "text-muted": "#9da9a0",
    "text-secondary": "#d3c6aa",
    "text": "#d3c6aa",
    "accent": "#a7c080",
    "accent-soft": "#83c092",
    "accent-fill": "#a7c080",
    "on-accent": "#232a2e",
    "success": "#a7c080",
    "warning": "#dbbc7f",
    "warning-soft": "#e69875",
    "danger": "#e67e80",
    "info": "#7fbbb3",
    "info-soft": "#83c092",
    "cyan": "#83c092",
    "magenta": "#d699b6",
    "cursor": "#d3c6aa",
    "shadow": "rgba(0, 0, 0, 0.42)",
    "scrim": "rgba(15, 20, 22, 0.68)",
    "input-bg": "#343f44"
  },
  "syntax": {
    "inline": {
      "name": "everforest-dark",
      "type": "dark",
      "colors": {
        "editor.background": "#2d353b",
        "editor.foreground": "#d3c6aa"
      },
      "tokenColors": [
        {
          "scope": ["comment", "punctuation.definition.comment", "comment.block.documentation"],
          "settings": { "foreground": "#9da9a0", "fontStyle": "italic" }
        },
        {
          "scope": [
            "string",
            "string.quoted",
            "string.quoted.single",
            "string.quoted.double",
            "string.quoted.template",
            "string.quoted.other",
            "string.unquoted",
            "string.regexp",
            "punctuation.definition.string"
          ],
          "settings": { "foreground": "#a7c080" }
        },
        {
          "scope": [
            "constant",
            "constant.numeric",
            "constant.language",
            "constant.character",
            "constant.character.escape",
            "constant.other",
            "support.constant"
          ],
          "settings": { "foreground": "#d699b6" }
        },
        {
          "scope": [
            "keyword",
            "keyword.control",
            "keyword.other",
            "keyword.operator.new",
            "storage",
            "storage.type",
            "storage.modifier",
            "keyword.function"
          ],
          "settings": { "foreground": "#e67e80" }
        },
        {
          "scope": [
            "keyword.operator.arithmetic",
            "keyword.operator.relational",
            "keyword.operator.logical",
            "keyword.operator.comparison"
          ],
          "settings": { "foreground": "#e69875" }
        },
        {
          "scope": ["variable.language", "variable.other.readwrite.alias"],
          "settings": { "foreground": "#e67e80" }
        },
        {
          "scope": [
            "entity.name.function",
            "support.function",
            "variable.function",
            "meta.function-call",
            "meta.method-call"
          ],
          "settings": { "foreground": "#a7c080" }
        },
        {
          "scope": [
            "entity.name.type",
            "entity.name.class",
            "entity.name.struct",
            "entity.name.enum",
            "entity.name.interface",
            "support.type",
            "support.class",
            "entity.other.inherited-class"
          ],
          "settings": { "foreground": "#dbbc7f" }
        },
        {
          "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
          "settings": { "foreground": "#e67e80" }
        },
        {
          "scope": [
            "entity.other.attribute-name",
            "meta.attribute",
            "entity.name.decorator",
            "punctuation.definition.annotation",
            "meta.decorator"
          ],
          "settings": { "foreground": "#e69875" }
        },
        {
          "scope": [
            "meta.object-literal.key",
            "meta.mapping.key",
            "support.type.property-name.css",
            "support.type.property-name.scss"
          ],
          "settings": { "foreground": "#7fbbb3" }
        },
        {
          "scope": ["support.constant.property-value", "support.constant.color"],
          "settings": { "foreground": "#d699b6" }
        },
        {
          "scope": ["markup.heading", "markup.heading entity.name"],
          "settings": { "foreground": "#e69875", "fontStyle": "bold" }
        },
        {
          "scope": "markup.list",
          "settings": { "foreground": "#e69875" }
        },
        {
          "scope": ["markup.bold"],
          "settings": { "fontStyle": "bold" }
        },
        {
          "scope": ["markup.italic"],
          "settings": { "fontStyle": "italic" }
        },
        {
          "scope": ["markup.raw", "markup.inline.raw", "markup.fenced_code", "markup.raw.block"],
          "settings": { "foreground": "#a7c080" }
        },
        {
          "scope": ["markup.inserted"],
          "settings": { "foreground": "#a7c080" }
        },
        {
          "scope": ["markup.deleted"],
          "settings": { "foreground": "#e67e80" }
        },
        {
          "scope": ["markup.changed"],
          "settings": { "foreground": "#dbbc7f" }
        },
        {
          "scope": ["markup.underline", "markup.underline.link", "string.other.link"],
          "settings": { "foreground": "#7fbbb3" }
        }
      ]
    }
  }
}
